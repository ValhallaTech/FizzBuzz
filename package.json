{
  "name": "fizz-buzz",
  "version": "1.0.0",
  "description": "Interactive FizzBuzz coding challenge web app",
  "scripts": {
    "dev": "parcel src/index.html src/solve.html src/code.html",
    "build": "parcel build src/index.html src/solve.html src/code.html --public-url ./",
    "clean": "rimraf dist .parcel-cache",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.{js,html,css}\"",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "7.2.0",
    "@popperjs/core": "2.11.8",
    "bootstrap": "5.3.8",
    "prismjs": "1.30.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@eslint/js": "10.0.1",
    "@parcel/transformer-inline-string": "2.16.4",
    "babel-jest": "30.3.0",
    "eslint": "10.2.0",
    "globals": "17.5.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "parcel": "2.16.4",
    "prettier": "3.8.2",
    "rimraf": "6.1.3"
  },
  "packageManager": "yarn@4.14.1",
  "browserslist": [
    "last 2 versions",
    "not dead",
    "> 0.2%"
  ]
}
